<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme — no action bar, all-dark window -->
    <style name="Theme.Bandapa" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">#131313</item>
        <item name="android:navigationBarColor">#131313</item>
        <item name="android:windowBackground">#131313</item>
    </style>

    <!--
      Splash-screen theme (androidx.core:core-splashscreen).
      On API 26–30 : library draws a centered icon on windowSplashScreenBackground.
      On API 31+   : system draws the adaptive icon in a 240dp circle;
                     windowSplashScreenIconBackgroundColor fills that circle (#1E1E1E = Surface).
      postSplashScreenTheme swaps back to Theme.Bandapa once content is ready.
    -->
    <style name="Theme.Bandapa.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#131313</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#1E1E1E</item>
        <item name="postSplashScreenTheme">@style/Theme.Bandapa</item>
    </style>

</resources>
